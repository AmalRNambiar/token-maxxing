{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "token-maxxing",
  "version": "0.1.1",
  "identifier": "com.tokenmaxxing.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Token Maxxing",
        "width": 280,
        "height": 240,
        "minWidth": 200,
        "minHeight": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
